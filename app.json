{
  "expo": {
    "name": "AnimOrg",
    "slug": "animorg",
    "scheme": "animorg",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B0B0B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.nexora.animorg",
      "versionCode": 6,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AnimOrg to access your photos to select custom anime avatars.",
          "cameraPermission": "Allow camera access to personalize your anime identity."
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#0B0B0B",
          "dark": {
            "image": "./assets/splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#0B0B0B"
          }
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "itisnexora",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2a3be68-4799-4025-ab7c-f3f8070eff20"
      }
    }
  }
}